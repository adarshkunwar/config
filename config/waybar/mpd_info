#!/bin/bash
status=$(mpc status 2>/dev/null | grep -o '\[.*\]' | tr -d '[]')
if [ -z "$status" ] || [ "$status" = "" ]; then
  echo "mpd offline"
  exit 0
fi

artist=$(mpc current --format "%artist%" 2>/dev/null)
title=$(mpc current --format "%title%" 2>/dev/null)
elapsed=$(mpc status 2>/dev/null | awk 'NR==2{print $3}' | cut -d'/' -f1)
total=$(mpc status 2>/dev/null | awk 'NR==2{print $3}' | cut -d'/' -f2)

if [ -n "$artist" ] && [ -n "$title" ]; then
  echo "$artist – $title  $elapsed/$total"
elif [ -n "$title" ]; then
  echo "$title  $elapsed/$total"
else
  echo "—"
fi
